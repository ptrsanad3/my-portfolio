<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Peter Ebraheem</title>
    <!-- Imports the ultra-thin Josefin Sans font from Google -->
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400&display=swap" rel="stylesheet">
  </head>
  <body>
    <!-- Fading Sticky Menu Bar -->
    <header class="top-nav">
      <div class="nav-links">
        <a href="#home">Home</a>
        <a href="#production">Production & Engineering</a>
        <a href="#arrangements">Arrangements</a>
        <a href="#education">Education</a>
        <a href="#contact">Contact</a>
      </div>
    </header>
    
    <!-- HERO SECTION -->
    <section class="hero-container" id="home">
      <!-- Background Image -->
      <img src="/images/hero-bg.png" alt="Peter Ebraheem" class="hero-bg" />
      
      <!-- Dark Overlay to make text readable -->
      <div class="hero-overlay"></div>
      
      <!-- Typography -->
      <div class="hero-content">
        <h1 class="hero-title">Peter Ebraheem</h1>
        <h2 class="hero-subtitle">Music Producer, Director, & Educator</h2>
      </div>
    </section>

    <!-- ABOUT SECTION -->
    <section id="about" class="about-section">
      <div class="about-card">
        
        <!-- Left Side: Portrait Image -->
        <div class="about-image-wrapper">
          <img src="/images/about-portrait.png" alt="Peter Ebraheem Portrait" class="about-image" />
        </div>

        <!-- Right Side: Content -->
        <div class="about-content">
          <p class="about-eyebrow">The Philosophy</p>
          <h2 class="about-heading">About Me</h2>
          
          <div class="about-text">
            <p>
              I've been working in the music industry for over a decade, producing tracks across a wide variety of genres. Currently, I'm at Berklee College of Music pursuing a dual major in Music Production & Engineering and Contemporary Writing & Production.
            </p>
            <p>
              For me, making music is about seeing the whole picture. While I love being behind the board producing and engineering, I also have a lot of experience directing and arranging for ensembles in both live and studio settings. Whether I'm building a track from scratch, mixing a record, or leading a band, my goal is simply to help bring great music to life.
            </p>
          </div>

          <a href="#contact" class="about-btn">GET IN TOUCH</a>
        </div>
        
      </div>
    </section>
  </body>
</html>

<style>
  /* Removes default borders */
  body, html {
    margin: 0;
    padding: 0;
    font-family: system-ui, -apple-system, sans-serif;
    background-color: #050505; /* Keeps the whole page background dark behind everything */
  }

  /* --- HERO SECTION --- */
