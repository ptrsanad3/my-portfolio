      gap: 15px; 
    }
    
    .nav-links a {
      margin-left: 0; 
      font-size: 0.85rem; 
    }

    /* 5. Mobile rules for the About Section */
    .about-card {
      flex-direction: column; /* Stacks the image on top of the text */
    }
    
    .about-image-wrapper {
