<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Peter Ebraheem</title>
    <!-- Imports the ultra-thin Josefin Sans font from Google -->
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400&display=swap" rel="stylesheet">
  </head>
  <body>
    <!-- Fading Sticky Menu Bar -->
    <header class="top-nav">
      <div class="nav-links">
        <a href="#home">Home</a>
        <a href="#production">Production & Engineering</a>
        <a href="#arrangements">Arrangements</a>
        <a href="#education">Education</a>
        <a href="#contact">Contact</a>
      </div>
    </header>
    
    <section class="hero-container">
      <!-- Background Image -->
      <!-- MAKE SURE THIS MATCHES YOUR EXACT FILE NAME IN THE IMAGES FOLDER -->
      <img src="/images/hero-bg.png" alt="Peter Ebraheem" class="hero-bg" />
      
      <!-- Dark Overlay to make text readable -->
      <div class="hero-overlay"></div>
      
      <!-- Typography -->
      <div class="hero-content">
        <h1 class="hero-title">Peter Ebraheem</h1>
        <h2 class="hero-subtitle">Music Producer, Director, & Educator</h2>
      </div>
    </section>
  </body>
</html>

<style>
  /* Removes default borders */
  body, html {
    margin: 0;
    padding: 0;
    font-family: system-ui, -apple-system, sans-serif;
  }

  /* The main wrapper */
  .hero-container {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 2; 
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* The background image */
  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover; 
    object-position: top center; 
    z-index: 1;
  }

  /* The dark tint */
  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4); 
    z-index: 2;
  }

  /* The text container */
  .hero-content {
    position: relative;
    z-index: 3; 
    text-align: center;
    color: white;
    padding: 20px;
    margin-top: 29vh; 
  }

  /* Styling for your name with the new thin font */
  .hero-title {
    font-family: 'Josefin Sans', sans-serif; 
    font-weight: 300; /* This makes the font thin and elegant */
    font-size: 5rem; 
    letter-spacing: -1px; 
    margin-bottom: 10px;
    margin-top: 0;
  }

  /* Styling for your titles */
  .hero-subtitle {
    font-size: 1.5rem;
    font-weight: 300;
    color: #e5e7eb; 
  }

  /* The fixed gradient menu bar */
  .top-nav {
    position: fixed; 
    top: 0;
    left: 0;
    width: 100%;
    box-sizing: border-box; 
    background: linear-gradient(to bottom, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 1) 75%, rgba(0, 0, 0, 0) 100%);
    padding: 25px 40px 50px 40px; 
    z-index: 100; 
    display: flex;
    justify-content: flex-end; 
  }

  /* Menu links */
  .nav-links a {
    color: white;
    text-decoration: none;
    margin-left: 35px; 
    font-size: 1.1rem;
    font-weight: 400;
    transition: opacity 0.3s ease; 
  }

  /* Hover effect */
  .nav-links a:hover {
    opacity: 0.6; 
  }
  /* --- MOBILE RESPONSIVENESS --- */
  @media (max-width: 768px) {
    /* 1. Make the container tall enough to fit the image and text */
    .hero-container {
      aspect-ratio: auto; /* Turns off the strict 3:2 ratio on phones */
      min-height: 85vh; /* Makes the image take up 85% of the phone screen height */
    }

    /* 2. Pull the text block up so it isn't pushed off the bottom */
    .hero-content {
      margin-top: 10vh; 
      padding: 10px;
    }

    /* 3. Shrink the massive fonts to fit the screen */
    .hero-title {
      font-size: 3rem; 
      letter-spacing: 0px;
    }
    
    .hero-subtitle {
      font-size: 1.1rem;
    }

    /* 4. Center and wrap the menu links so they don't squish */
    .top-nav {
      padding: 15px 10px 30px 10px;
      justify-content: center; 
    }
    
    .nav-links {
      display: flex;
      flex-wrap: wrap; /* Allows links to stack cleanly into two rows if needed */
      justify-content: center;
      gap: 15px; /* Adds even space between all links */
    }
    
    .nav-links a {
      margin-left: 0; /* Overrides the desktop left-margin */
      font-size: 0.85rem; 
    }
  }
</style>