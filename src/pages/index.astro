<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Peter Ebraheem</title>
  </head>
  <body>
    <!-- Fading Sticky Menu Bar -->
    <header class="top-nav">
      <div class="nav-links">
        <a href="#home">Home</a>
        <a href="#production">Production & Engineering</a>
        <a href="#arrangements">Arrangements</a>
        <a href="#education">Education</a>
        <a href="#contact">Contact</a>
      </div>
    </header>
    
    <section class="hero-container">
      <!-- Background Image -->
      <img src="/images/hero-bg.png" alt="Peter Ebraheem" class="hero-bg" />
      
      <!-- Dark Overlay to make text readable -->
      <div class="hero-overlay"></div>
      
      <!-- Typography -->
      <div class="hero-content">
        <h1 class="hero-title">Peter Ebraheem</h1>
        <h2 class="hero-subtitle">Music Producer, Director, & Educator</h2>
      </div>
    </section>
  </body>
</html>

<style>
  /* Removes default borders so the image touches the edges of the screen */
  body, html {
    margin: 0;
    padding: 0;
    font-family: system-ui, -apple-system, sans-serif;
  }

  /* The main wrapper controlling the size */
  .hero-container {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 2; /* Forces the container to perfectly match your image */
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Puts the image in the background */
  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover; 
    object-position: top center; /* Forces the image to start from its absolute top edge */
    z-index: 1;
  }

  /* The dark tint */
  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4); /* The 0.4 is 40% opacity. Change it to adjust darkness */
    z-index: 2;
  }

  /* Puts the text over the image and centers it */
  .hero-content {
    position: relative;
    z-index: 3; 
    text-align: center;
    color: white;
    padding: 20px;
  }

  /* Styling for your name */
  .hero-title {
    font-size: 4rem;
    margin-bottom: 10px;
    margin-top: 0;
  }

  /* Styling for your titles */
  .hero-subtitle {
    font-size: 1.5rem;
    font-weight: 300;
    color: #e5e7eb; 
  }

  /* The fixed gradient menu bar */
  .top-nav {
    position: fixed; 
    top: 0;
    left: 0;
    width: 100%;
    box-sizing: border-box; /* Keeps the menu exactly within the screen width */
    
    /* Solid black for the first 75%, then a quick fade at the bottom 25% */
    background: linear-gradient(to bottom, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 1) 75%, rgba(0, 0, 0, 0) 100%);
    
    padding: 25px 40px 50px 40px; 
    z-index: 100; /* Ensures the menu always stays on top of your images */
    display: flex;
    justify-content: flex-end; /* Aligns the menu items to the right side */
  }

  /* Styling the individual links */
  .nav-links a {
    color: white;
    text-decoration: none;
    margin-left: 35px; /* Spacing between the links */
    font-size: 1.1rem;
    font-weight: 400;
    transition: opacity 0.3s ease; /* Makes the hover effect smooth */
  }

  /* Gentle fade effect when someone hovers their mouse over a link */
  .nav-links a:hover {
    opacity: 0.6; 
  }
</style>