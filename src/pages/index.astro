  }

  .about-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Right Side: The Text */
  .about-content {
    flex: 1.2; 
    padding: 60px 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .about-eyebrow {
