---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Peter Ebraheem | Portfolio</title>
	</head>
	<body class="bg-zinc-950 text-white font-sans antialiased">
		
		<!-- NAVIGATION BAR -->
		<nav class="flex justify-between items-center py-8 px-8 md:px-16 border-b border-zinc-900">
			<div class="text-xl font-bold tracking-widest uppercase">
				Peter Ebraheem
			</div>
			<div class="space-x-8 text-sm font-medium text-zinc-400">
				<a href="#" class="hover:text-white transition-colors">Audio</a>
				<a href="#" class="hover:text-white transition-colors">Visuals</a>
				<a href="#" class="hover:text-white transition-colors">Engineering</a>
			</div>
		</nav>

        <!-- HERO SECTION -->
        <main class="flex flex-col items-center justify-center min-h-[75vh] text-center px-6">
            <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6">Sound, Cinema & Systems.</h1>
            <p class="text-lg text-zinc-400 max-w-2xl leading-relaxed">
                Specializing in rhythmically dense production, analog console mixing, and high-fidelity cinematography.
            </p>
        </main>

	</body>
</html>